  "keyFeatures": [
    "Multi-location inventory management with stock movements and unit conversions",
    "Cash session tracking with registers, terminals, and expense management",
    "Employee attendance tracking with check-in/out and lunch break management",
    "Role-based access control with Spatie permissions and Passport OAuth",
    "Operating unit management for branches and temporary events",
    "Comprehensive API with Swagger documentation and Single Action Controllers"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/login - Authenticate user with email and password",
    "POST /api/v1/auth/logout - Invalidate current access token",
    "GET /api/v1/auth/me - Get authenticated user profile",
    "GET /api/v1/items - List all items with pagination",
    "POST /api/v1/items - Create new item",
    "GET /api/v1/item-variants - List item variants with filters",
    "POST /api/v1/item-variants - Create item variant",
    "GET /api/v1/inventory-locations - List inventory locations",
    "POST /api/v1/inventory-locations - Create inventory location",
    "GET /api/v1/stock - List stock by location and variant",
    "POST /api/v1/inventory/opening-balance - Register opening balance",
    "POST /api/v1/inventory/stock-out - Register stock out movement",
    "GET /api/v1/employees - List employees with filters",
    "POST /api/v1/employees - Create new employee",
    "PUT /api/v1/employees/{id} - Update employee details",
    "GET /api/v1/employees/{id}/wages - List employee wage history",
    "POST /api/v1/employees/{id}/wages - Create wage entry",
    "GET /api/v1/attendance/today - Get today's attendance records",
    "POST /api/v1/attendance/check-in - Register employee check-in",
    "POST /api/v1/attendance/check-out - Register employee check-out",
    "GET /api/v1/operating-units - List operating units",
    "POST /api/v1/operating-units - Create operating unit"
  ]
}
